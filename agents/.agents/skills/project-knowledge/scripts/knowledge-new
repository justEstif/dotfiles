#!/usr/bin/env python3
from __future__ import annotations

import argparse
from datetime import date
from pathlib import Path
import sys

sys.path.insert(0, str(Path(__file__).resolve().parent))
from _knowledge_lib import TYPE_DIRS, slugify

TEMPLATE_DIR = Path(__file__).resolve().parents[1] / 'assets' / 'templates'

parser = argparse.ArgumentParser(description='Create a templated project knowledge note')
parser.add_argument('type', choices=TYPE_DIRS)
parser.add_argument('title')
parser.add_argument('--tags', default='', help='comma-separated tags')
args = parser.parse_args()

today = date.today().isoformat()
slug = slugify(args.title)
tags = ', '.join(slugify(t) for t in args.tags.split(',') if t.strip())
text = (TEMPLATE_DIR / f'{args.type}.md').read_text()
text = text.replace('{{date}}', today).replace('{{slug}}', slug).replace('{{title}}', args.title).replace('{{tags}}', tags)
folder = Path('knowledge') / TYPE_DIRS[args.type]
folder.mkdir(parents=True, exist_ok=True)
path = folder / f'{today}-{slug}.md'
if path.exists():
    raise SystemExit(f'error: {path} already exists')
path.write_text(text)
print(path)
