#!/usr/bin/env python3
from __future__ import annotations

import re, sys
from pathlib import Path
sys.path.insert(0, str(Path(__file__).resolve().parent))
from _knowledge_lib import TYPE_DIRS, STATUSES, REQUIRED_SECTIONS, LENGTH_WARN, iter_notes, note_rel, KNOWLEDGE

errors=[]; warnings=[]; ids={}
notes = iter_notes()
existing = {p.resolve() for p in KNOWLEDGE.rglob('*.md')} if KNOWLEDGE.exists() else set()

for n in notes:
    rel = note_rel(n.path)
    if '__error__' in n.meta:
        errors.append(f'{rel}: {n.meta["__error__"]}')
        continue
    for field in ['id','type','title','created','updated','status','tags']:
        if field not in n.meta or n.meta[field] in ('', None):
            errors.append(f'{rel}: missing frontmatter field {field}')
    typ = n.meta.get('type')
    if typ not in TYPE_DIRS:
        errors.append(f'{rel}: invalid type {typ!r}')
        continue
    if n.meta.get('status') not in STATUSES[typ]:
        errors.append(f'{rel}: invalid status {n.meta.get("status")!r} for {typ}')
    expected = Path('knowledge') / TYPE_DIRS[typ]
    try:
        parent = n.path.parent.relative_to(Path.cwd())
    except ValueError:
        parent = n.path.parent
    if parent.as_posix() != expected.as_posix():
        errors.append(f'{rel}: {typ} must live in {expected}/')
    nid = n.meta.get('id')
    if nid in ids:
        errors.append(f'{rel}: duplicate id {nid} also in {ids[nid]}')
    else:
        ids[nid] = rel
    sections = set(re.findall(r'^##\s+(.+?)\s*$', n.body, flags=re.M))
    for section in REQUIRED_SECTIONS[typ]:
        if section not in sections:
            errors.append(f'{rel}: missing section ## {section}')
    tags = n.meta.get('tags')
    if not isinstance(tags, list):
        errors.append(f'{rel}: tags must be a flat list')
    elif not tags:
        warnings.append(f'{rel}: tags is empty')
    lines = n.path.read_text().splitlines()
    if len(lines) > LENGTH_WARN[typ]:
        warnings.append(f'{rel}: {len(lines)} lines exceeds {LENGTH_WARN[typ]} line warning threshold')
    if typ != 'source' and len(lines) > 400:
        errors.append(f'{rel}: non-source note exceeds 400 lines')
    if typ == 'source' and n.meta.get('status') == 'processed':
        m = re.search(r'^## Extracted Items\s*(.*?)(?:^##\s|\Z)', n.body, flags=re.M|re.S)
        if m and not m.group(1).strip():
            warnings.append(f'{rel}: processed source has empty Extracted Items')

    for target in re.findall(r'\[[^\]]+\]\(([^)]+\.md)\)', n.body):
        if '://' in target:
            continue
        target_path = (n.path.parent / target).resolve()
        root_relative = (Path.cwd() / target).resolve()
        if target_path not in existing and root_relative not in existing:
            errors.append(f'{rel}: broken markdown link {target}')
    for target in re.findall(r'\[\[([^\]]+?)(?:\|[^\]]+)?\]\]', n.body):
        candidates = list(KNOWLEDGE.rglob(f'{target}.md')) if KNOWLEDGE.exists() else []
        if not candidates and target not in ids:
            errors.append(f'{rel}: broken wiki link [[{target}]]')

for w in warnings:
    print('WARN:', w)
for e in errors:
    print('ERROR:', e, file=sys.stderr)
if errors:
    raise SystemExit(1)
print(f'knowledge lint passed ({len(notes)} files, {len(warnings)} warnings)')
