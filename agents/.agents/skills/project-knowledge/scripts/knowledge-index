#!/usr/bin/env python3
from __future__ import annotations

from collections import defaultdict
from datetime import date
from pathlib import Path
import sys
sys.path.insert(0, str(Path(__file__).resolve().parent))
from _knowledge_lib import iter_notes, note_rel

idx = Path('knowledge/indexes')
idx.mkdir(parents=True, exist_ok=True)
today = date.today().isoformat()
notes = [n for n in iter_notes() if '__error__' not in n.meta and n.meta.get('type') != 'index']

def header(id_, title):
    return f"---\nid: {id_}\ntype: index\ntitle: {title}\ncreated: {today}\nupdated: {today}\nstatus: active\ntags: []\n---\n\n## Purpose\n\nGenerated index.\n\n## Key Links\n\n"

def link(n):
    return f"- [{n.meta.get('title')}]({note_rel(n.path)}) — `{n.meta.get('type')}` `{n.meta.get('status')}` `{n.meta.get('id')}`\n"

all_md = header('index-all', 'All Knowledge') + ''.join(link(n) for n in notes) + '\n## Open Questions\n\nSee open-questions.md.\n\n## Recent Changes\n\nGenerated by scripts/knowledge-index.\n'
(idx / 'all.md').write_text(all_md)

decisions = [n for n in notes if n.meta.get('type') == 'decision']
(idx / 'decisions.md').write_text(header('index-decisions', 'Decisions') + ''.join(link(n) for n in decisions) + '\n## Open Questions\n\nN/A.\n\n## Recent Changes\n\nGenerated by scripts/knowledge-index.\n')

questions = [n for n in notes if n.meta.get('type') == 'question' and n.meta.get('status') == 'open']
(idx / 'open-questions.md').write_text(header('index-open-questions', 'Open Questions') + ''.join(link(n) for n in questions) + '\n## Open Questions\n\n' + ''.join(link(n) for n in questions) + '\n## Recent Changes\n\nGenerated by scripts/knowledge-index.\n')

by_tag = defaultdict(list)
for n in notes:
    for tag in n.meta.get('tags') or []:
        by_tag[tag].append(n)
body = header('index-tags', 'Tags')
for tag in sorted(by_tag):
    body += f"### {tag}\n\n" + ''.join(link(n) for n in by_tag[tag]) + '\n'
body += '\n## Open Questions\n\nSee open-questions.md.\n\n## Recent Changes\n\nGenerated by scripts/knowledge-index.\n'
(idx / 'tags.md').write_text(body)
print('generated knowledge indexes')
