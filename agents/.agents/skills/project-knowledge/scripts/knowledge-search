#!/usr/bin/env python3
from __future__ import annotations

import argparse, json, sys
from pathlib import Path
sys.path.insert(0, str(Path(__file__).resolve().parent))
from _knowledge_lib import iter_notes, note_rel

parser = argparse.ArgumentParser(description='Search project knowledge notes')
parser.add_argument('query', nargs='?', default='')
parser.add_argument('--type')
parser.add_argument('--status')
parser.add_argument('--tag')
parser.add_argument('--json', action='store_true')
parser.add_argument('--files-only', action='store_true')
args = parser.parse_args()

results = []
q = args.query.lower()
for n in iter_notes():
    if '__error__' in n.meta:
        continue
    if args.type and n.meta.get('type') != args.type:
        continue
    if args.status and n.meta.get('status') != args.status:
        continue
    if args.tag and args.tag not in (n.meta.get('tags') or []):
        continue
    hay = (n.meta.get('title','') + '\n' + n.body).lower()
    if q and q not in hay:
        continue
    item = {
        'path': note_rel(n.path),
        'id': n.meta.get('id'),
        'type': n.meta.get('type'),
        'status': n.meta.get('status'),
        'title': n.meta.get('title'),
        'tags': n.meta.get('tags') or [],
    }
    results.append(item)

if args.json:
    print(json.dumps(results, indent=2))
elif args.files_only:
    print('\n'.join(r['path'] for r in results))
else:
    for r in results:
        tags = ','.join(r['tags'])
        print(f"{r['path']} | {r['type']} | {r['status']} | {r['id']} | {r['title']} | {tags}")
